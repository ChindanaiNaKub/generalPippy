{
  "$schema": "https://opencode.ai/config.json",

  // GeneralPippy v3.2.0 — Self-Driving Goal Agent
  // Default agent: pippy — plan, execute, verify, iterate
  "default_agent": "pippy",

  // Models
  "model": "opencode-go/deepseek-v4-flash",    // Coordination: budget-first primary loop
  "small_model": "opencode-go/deepseek-v4-flash", // System tasks: titles, summaries, compaction

  // Plugins
  "plugin": [
    "@tarquinen/opencode-dcp@0.0.4",
    "cc-safety-net@1.0.6"
  ],

  // MCP servers
  "mcp": {
    "jcodemunch": {
      "type": "local",
      "command": ["uvx", "--from", "git+https://github.com/jgravelle/jcodemunch-mcp.git@v1.0.0", "jcodemunch-mcp"],
      "enabled": true
    }
  },

  // Compaction
  "compaction": {
    "auto": true,
    "prune": true,
    "reserved": 10000
  },

  // Formatters
  "formatter": true,

  // LSP servers
  "lsp": true,

  // References
  // OpenCode includes described references in agent context and allows the
  // referenced directories through its external-directory boundary.
  "references": {
    "opencode-docs": {
      "path": "./references/opencode",
      "description": "Use when editing GeneralPippy/OpenCode config, agents, providers, references, permissions, or troubleshooting setup"
    }
  }

  // Agent definitions live in agents/*.md.
  // Do not redeclare them here: partial JSON agent stubs can shadow markdown
  // frontmatter such as model, permission.task, and prompts.
}

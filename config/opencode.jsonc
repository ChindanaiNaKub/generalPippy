{
  "$schema": "https://opencode.ai/config.json",

  // GeneralPippy v2.1 — Self-Driving Goal Agent
  // Default agent: pippy — plan, execute, verify, iterate
  "default_agent": "pippy",

  // Models
  "model": "opencode-go/kimi-k2.7-code",        // Planning: strong, code-specialized
  "small_model": "opencode-go/deepseek-v4-flash", // System tasks: titles, summaries, compaction

  // Plugins
  "plugin": [
    "@tarquinen/opencode-dcp@latest"
  ],

  // MCP servers
  "mcp": {
    "jcodemunch": {
      "type": "local",
      "command": ["uvx", "--from", "git+https://github.com/jgravelle/jcodemunch-mcp.git", "jcodemunch-mcp"],
      "enabled": true
    }
  },

  // Compaction
  "compaction": {
    "auto": true,
    "prune": true,
    "reserved": 10000
  },

  // Formatters
  "formatter": true,

  // Agent definitions
  "agent": {
    "pippy": {
      "mode": "primary",
      "description": "Self-driving goal agent — plan, execute, verify, iterate until objective is met"
    },
    "pippy-plan": {
      "mode": "subagent",
      "description": "Planning and architecture — uses strong model for design and stuck-step diagnosis"
    },
    "pippy-build": {
      "mode": "subagent",
      "description": "Implementation — uses cheap model for coding tasks"
    }
  }
}

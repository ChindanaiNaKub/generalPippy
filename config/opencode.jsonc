{
  "$schema": "https://opencode.ai/config.json",

  // GeneralPippy v2.3 — Self-Driving Goal Agent
  // Default agent: pippy — plan, execute, verify, iterate
  "default_agent": "pippy",

  // Models
  "model": "opencode-go/kimi-k2.7-code",        // Planning: strong, code-specialized
  "small_model": "opencode-go/deepseek-v4-flash", // System tasks: titles, summaries, compaction

  // Plugins
  "plugin": [
    "@tarquinen/opencode-dcp@0.0.4"
  ],

  // MCP servers
  "mcp": {
    "jcodemunch": {
      "type": "local",
      "command": ["uvx", "--from", "git+https://github.com/jgravelle/jcodemunch-mcp.git@v0.1.0", "jcodemunch-mcp"],
      "enabled": true
    }
  },

  // Compaction
  "compaction": {
    "auto": true,
    "prune": true,
    "reserved": 10000
  },

  // Formatters
  "formatter": true

  // Agent definitions live in agents/*.md.
  // Do not redeclare them here: partial JSON agent stubs can shadow markdown
  // frontmatter such as model, permission.task, and prompts.
}
